{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "mocha",
      "hardhat",
      "@nomicfoundation/hardhat-chai-matchers"
    ],
    "outDir": "dist"
  },
  "include": ["./scripts", "./test", "./hardhat.config.ts"]
}
